cat > .gitignore << 'EOF'
# Credentials — NEVER commit
pipeline_config.json

# Database files
*.db
*.sqlite
*.sqlite3

# Backups
backups/

# Generated output (rebuilt by --process)
output/

# Temp files
temp_images/

# OS junk
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.log

# Editor
*.swp
*~
.vscode/
.idea/
EOFsrc/api/config.php
pipeline_config.json
